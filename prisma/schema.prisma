// The Customer Life Graph — the single shared data model all three
// agents (Pulse, Yield, Shield) read from and write to.
//
// Backend/agents track owns this file. If you change a model here,
// ping the frontend track before merging — it changes the API shape.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  accounts      Account[]
  calendarEvents CalendarEvent[]
  subscriptions Subscription[]
  agentActions  AgentAction[]
  createdAt     DateTime       @default(now())
}

model Account {
  id           String        @id @default(cuid())
  user         User          @relation(fields: [userId], references: [id])
  userId       String
  name         String // e.g. "DBS Multiplier"
  type         String // "savings" | "current" | "fixed_deposit"
  balance      Float
  interestRate Float // annual %, e.g. 0.05 for idle savings
  currency     String        @default("SGD")
  transactions Transaction[]
}

model Transaction {
  id        String   @id @default(cuid())
  account   Account  @relation(fields: [accountId], references: [id])
  accountId String
  merchant  String
  amount    Float
  category  String // "subscription" | "travel" | "general" ...
  occurredAt DateTime
}

model CalendarEvent {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String // "Flight to Seoul"
  location  String?
  startsAt  DateTime
  endsAt    DateTime
  // Orbit Pulse reads this to infer life events (trips, moves, etc.)
  inferredEventType String? // "trip" | "relocation" | "unknown"
}

model Subscription {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  merchant      String // "Disney+"
  monthlyAmount Float
  lastUsedAt    DateTime?
  usageScore    Float    @default(1) // 0 = never used, 1 = used constantly
  status        String   @default("active") // "active" | "flagged" | "cancelled"
}

// Every autonomous suggestion or action any agent takes, for the
// MAS-compliant audit trail. Nothing executes without a matching row here.
//
// id is a deterministic string minted by the agent rule functions (e.g.
// "pulse_evt_korea"), not an auto-generated cuid — this lets syncAgentActions
// upsert on every request instead of creating duplicate rows.
model AgentAction {
  id          String   @id
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  agent       String // "pulse" | "yield" | "shield"
  actionType  String // "recommendation" | "autonomous_action"
  description String
  requiresApproval Boolean @default(true)
  status      String   @default("pending") // "pending" | "approved" | "dismissed"
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
}

# Local SQLite for the MVP - swap for Postgres later without changing app code
DATABASE_URL="file:./dev.db"

# Signs session cookies. Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-random-value"

# Only needed once an agent calls out to a real LLM instead of the mock rules engine
# ANTHROPIC_API_KEY=
